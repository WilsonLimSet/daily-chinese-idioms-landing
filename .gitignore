# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# audit credentials + outputs (never commit these)
.gsc-oauth.json
.gsc-token.json
.vercel-token
audits/data/

# runtime state files for content/translation scripts
.quora-history.json
.translate-new-progress.json
.medium-history.json
.series-history.json

# typescript
*.tsbuildinfo
next-env.d.ts
