{
  "rewrites": [
    {
      "source": "/ads.txt",
      "has": [
        {
          "type": "host",
          "value": "chineseidioms.com"
        }
      ],
      "destination": "https://www.chineseidioms.com/ads.txt"
    }
  ],
  "redirects": [
    {
      "source": "/((?!ads.txt).*)",
      "has": [
        {
          "type": "host",
          "value": "chineseidioms.com"
        }
      ],
      "destination": "https://www.chineseidioms.com/$1",
      "permanent": true
    },
    {
      "source": "/blog/:year(\\d{4})-:month(\\d{2})-:day(\\d{2})-:slug(.*)",
      "destination": "/blog/:slug",
      "permanent": true
    },
    {
      "source": "/:lang(ar|es|fr|hi|id|ja|ko|ms|pt|ru|th|tl|vi)/blog/:year(\\d{4})-:month(\\d{2})-:day(\\d{2})-:slug(.*)",
      "destination": "/:lang/blog/:slug",
      "permanent": true
    },
    {
      "source": "/listicles/:slug(.*)",
      "destination": "/blog/lists/:slug",
      "permanent": true
    },
    {
      "source": "/:lang(ar|es|fr|hi|id|ja|ko|ms|pt|ru|th|tl|vi)/listicles/:slug(.*)",
      "destination": "/:lang/blog/lists/:slug",
      "permanent": true
    },
    {
      "source": "/:lang(ar|es|fr|hi|id|ja|ko|ms|pt|ru|th|tl|vi)/themes",
