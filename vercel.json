{
  "rewrites": [
    {
      "source": "/ads.txt",
      "has": [
        {
          "type": "host",
          "value": "chineseidioms.com"
        }
      ],
      "destination": "https://www.chineseidioms.com/ads.txt"
    }
  ],
  "redirects": [
    {
      "source": "/((?!ads.txt).*)",
      "has": [
        {
          "type": "host",
          "value": "chineseidioms.com"
        }
      ],
      "destination": "https://www.chineseidioms.com/$1",
      "permanent": true
    },
    {
      "source": "/blog/:year(\\d{4})-:month(\\d{2})-:day(\\d{2})-:slug(.*)",
      "destination": "/blog/:slug",
      "permanent": true
    },
    {
      "source": "/:lang(es|pt|id|vi|ja|ko|th|hi|ar|fr|tl|ms|ru)/blog/:year(\\d{4})-:month(\\d{2})-:day(\\d{2})-:slug(.*)",
      "destination": "/:lang/blog/:slug",
      "permanent": true
    },
    {
      "source": "/th/blog/lists/samnuan-jiin-wan-pii-mai",
      "destination": "/th/blog/lists/samnuuk-chin-wan-pi-mai",
      "permanent": true
    },
    {
      "source": "/ja/blog/lists/sotsugyou-shiki-chuugokugo-kanyouku",
      "destination": "/ja/blog/lists/sotsugyou-shiki-no-chuugokugo-ijisetto",
      "permanent": true
    },
    {
      "source": "/ko/blog/lists/ujong-e-daehan-uimi-inneun-junggugeo-sogeo-8gae",
      "destination": "/ko/blog/lists/ujong-e-daehan-jungguk-seogeo",
      "permanent": true
    },
    {
      "source": "/blog/qian-lu-ji-qiong",
      "destination": "/blog/qian-lv-ji-qiong",
      "permanent": true
    },
    {
      "source": "/:lang(es|pt|id|vi|ja|ko|th|hi|ar|fr|tl|ms|ru)/blog/qian-lu-ji-qiong",
      "destination": "/:lang/blog/qian-lv-ji-qiong",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "all"
        }
      ]
    },
    {
      "source": "/(.+\\.(?:svg|jpg|jpeg|png|webp|avif|gif))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
